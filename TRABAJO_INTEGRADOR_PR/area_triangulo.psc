Algoritmo AreaTriangulo
    Definir base, altura Como Entero
    Definir area Como Real
    
    Escribir "Ingresa la base del triangulo:"
    Leer base
    
    Escribir "Ingresa la altura del triangulo:"
    Leer altura
    
    // formula
    area <- (base * altura) / 2
    
    Escribir "El area del triangulo es: ", area
FinAlgoritmo